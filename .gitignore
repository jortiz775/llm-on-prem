# ---- Python -------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage
coverage.xml

# ---- Environment / secrets ----------------------------------------
# NEVER commit API keys, passwords, or tokens.
.env
.env.local
.env.*.local

# ---- Models & embeddings ------------------------------------------
# Model weights are large binary files — store them outside the repo
# or use Ollama's model library instead.
models/
*.gguf
*.bin
*.safetensors
*.pt
*.pth

# ---- Vector store data --------------------------------------------
# ChromaDB persists its index to disk — exclude these generated files.
chroma_db/
vector_store/
*.index

# ---- Documents (client data) --------------------------------------
# Raw input documents may contain sensitive information.
data/documents/
data/raw/

# ---- Jupyter ------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---- Node ---------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Next.js ------------------------------------------------------
ui/.next/
ui/out/
ui/build/
ui/.vercel/
*.tsbuildinfo

# ---- Docker -------------------------------------------------------
docker-compose.override.yml
.docker/

# ---- Logs ---------------------------------------------------------
logs/
*.log

# ---- OS -----------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---- IDE ----------------------------------------------------------
.vscode/settings.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*.suo
*.user
*.userosscache
*.sln.docstates

# ---- Auth / session state -----------------------------------------
.auth/
storageState.json

# ---- Test artifacts -----------------------------------------------
playwright-report/
test-results/
screenshots/
